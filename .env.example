# Environment template for LatestNews.
#
# Real values belong in `.env` (git-ignored) or — for API keys — the OS
# keychain via the `keyring` library. Ship no secrets in this file.

# --- LLM provider keys (Story 3.x will consume these) ------------------------
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Data root (Story 9.1 onwards) -------------------------------------------
# LATESTNEWS_DATA_ROOT=~/Documents/LatestNews
